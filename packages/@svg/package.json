{
  "name": "@jilatax/svg",
  "version": "0.0.3",
  "packageManager": "bun@1.3.4",
  "description": "Compile SVG icons into typed ReactLynx components for Jilatax applications.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.js"
      },
      "require": {
        "types": "./dist/plugin.d.cts",
        "default": "./dist/plugin.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./types/svg.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./types/svg.d.cts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "plugin": ["dist/plugin.d.ts"],
      "react": ["dist/react.d.ts"],
      "types": ["types/svg.d.ts"]
    }
  },
  "files": ["dist", "types"],
  "sideEffects": false,

  "keywords": ["android", "icons", "lynx", "lynxjs", "rspeedy", "svg"],
  "author": "Gohit X (bastndev)",
  "license": "MIT",
  "homepage": "https://jilatax.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jilatax/jilatax.git"
  },
  "bugs": {
    "url": "https://github.com/jilatax/jilatax/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18.0"
  },

  "dependencies": {
    "saxes": "^6.0.0"
  },

  "peerDependencies": {
    "@lynx-js/react": ">=0.116.2 <1",
    "@lynx-js/types": ">=3.7.0 <4",
    "@types/react": "^18.3.20"
  },

  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@lynx-js/react": "^0.116.2",
    "@lynx-js/types": "^3.7.0",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.20",
    "publint": "^0.3.21",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && node test/smoke.mjs",
    "check": "bun run typecheck && bun run test",
    "prepack": "bun run check"
  }
}
