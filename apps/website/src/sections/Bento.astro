---
import { ArrowUpRight, Braces, Gauge, Smartphone, Zap } from '@lucide/astro';
import GithubIcon from '@/assets/icons/social/github.svg';
import { LINKS } from '@/consts';

// The three published packages (npm registry, image 3 of the brief).
const packages = [
  {
    name: 'jilatax',
    version: '0.0.9',
    description: 'Android-first application framework for Lynx and Rspeedy.',
    color: 'var(--color-green)',
    href: 'https://www.npmjs.com/package/jilatax',
  },
  {
    name: 'create-jilatax',
    version: '0.3.4',
    description: 'Create an Android-first Jilatax application for Lynx and Rspeedy.',
    color: 'var(--color-blue)',
    href: 'https://www.npmjs.com/package/create-jilatax',
  },
  {
    name: '@jilatax/cli',
    version: '0.1.2',
    description: 'Android build and device orchestration for Jilatax applications.',
    color: 'var(--color-coral)',
    href: 'https://www.npmjs.com/package/@jilatax/cli',
  },
  {
    name: '@jilatax/svg',
    version: '0.0.7',
    description: 'Compile SVG icons into typed ReactLynx components for Jilatax applications.',
    color: 'var(--color-amber)',
    href: 'https://www.npmjs.com/package/@jilatax/svg',
  },
];
---

<section class="bento" id="use">
  <header class="bento-head">
    <p class="kicker">How to use</p>
    <h2 class="title">Everything you need, <span class="gradient-text">packed tight.</span></h2>
    <p class="sub">
      Framework, scaffolder and CLI — four packages that take you from an empty
      folder to a running Android app.
    </p>
  </header>

  <div class="grid">
    <!-- Terminal: the create flow -->
    <article class="card card-terminal span-2x2" style="--depth: 5px" data-spotlight>
      <div class="terminal-bar">
        <span class="dot dot-coral"></span>
        <span class="dot dot-amber"></span>
        <span class="dot dot-green"></span>
        <span class="terminal-title">terminal</span>
      </div>
      <pre class="terminal-body"><code><span class="t-dim">$</span> <span class="t-cmd">npm create jilatax@latest</span>

<span class="t-coral">┌</span>  <span class="t-bold">create-jilatax</span>  <span class="t-dim">v0.0.5</span>
<span class="t-coral">│</span>
<span class="t-green">◇</span>  Project name?
<span class="t-coral">│</span>  <span class="t-cmd">my-app</span>
<span class="t-coral">│</span>
<span class="t-green">◇</span>  Template
<span class="t-coral">│</span>  <span class="t-cmd">Lynx + Rspeedy</span> <span class="t-dim">· Android</span>
<span class="t-coral">│</span>
<span class="t-amber">└</span>  <span class="t-green">Ready!</span>  <span class="t-dim" id="bento-term-cmd">cd my-app && jilatax run android</span></code></pre>
    </article>

    <!-- Android-first -->
    <article class="card card-icon-animated" style="--depth: 12px; --accent-color: var(--color-green); --accent-rgb: 40, 200, 64" data-spotlight data-anim="smartphone">
      <span class="tile tile-green">
        <span class="icon-svg"><Smartphone size={22} aria-hidden="true" /></span>
      </span>
      <h3>Android-first</h3>
      <p>A native Gradle project lands in <code>./android</code> — manifests, flavors and device orchestration wired up for you.</p>
    </article>

    <!-- Lynx -->
    <article class="card card-icon-animated" style="--depth: 16px; --accent-color: var(--color-blue); --accent-rgb: 64, 169, 255" data-spotlight data-anim="zap">
      <span class="tile tile-blue">
        <span class="icon-svg"><Zap size={22} aria-hidden="true" /></span>
      </span>
      <h3>Lynx engine</h3>
      <p>Dual-threaded UI with instant first paint. Write once in TypeScript, render truly native views.</p>
    </article>

    <!-- Rspeedy -->
    <article class="card card-icon-animated" style="--depth: 14px; --accent-color: var(--color-green); --accent-rgb: 40, 200, 64" data-spotlight data-anim="gauge">
      <span class="tile tile-green">
        <span class="icon-svg"><Gauge size={22} aria-hidden="true" /></span>
      </span>
      <h3>Rspeedy builds</h3>
      <p>Rspack-powered bundling with sub-second HMR while you iterate on a real device.</p>
    </article>

    <!-- TypeScript -->
    <article class="card card-icon-animated" style="--depth: 18px; --accent-color: var(--color-blue); --accent-rgb: 64, 169, 255" data-spotlight data-anim="braces">
      <span class="tile tile-blue">
        <span class="icon-svg"><Braces size={22} aria-hidden="true" /></span>
      </span>
      <h3>TypeScript strict</h3>
      <p>Typed APIs end to end, plus a JSON-schema-validated app config out of the box.</p>
    </article>

    <!-- Packages -->
    <article class="card card-packages span-3" id="packages" style="--depth: 4px" data-spotlight>
      <h3 class="packages-title">Four packages, one toolbox</h3>
      <ul class="packages-list">
        {packages.map((pkg) => (
          <li>
            <a class="pkg" href={pkg.href} target="_blank" rel="noopener noreferrer">
              <span class="pkg-chip" style={`--pkg-color: ${pkg.color}`}></span>
              <span class="pkg-body">
                <span class="pkg-name">{pkg.name}</span>
                <span class="pkg-desc">{pkg.description}</span>
              </span>
              <span class="pkg-version">v{pkg.version}</span>
            </a>
          </li>
        ))}
      </ul>
    </article>

    <!-- Open source -->
    <a class="card card-oss" href={LINKS.github} target="_blank" rel="noopener noreferrer" style="--depth: 10px" data-spotlight>
      <span class="oss-top">
        <GithubIcon width={22} height={22} aria-hidden="true" />
        <ArrowUpRight size={18} aria-hidden="true" class="oss-arrow" />
      </span>
      <span class="oss-mit">MIT</span>
      <span class="oss-label">(JilaTax) Open source, forever.</span>
    </a>
  </div>
</section>

<style>
  .bento {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8rem 1.5rem 4.5rem;
  }

  /* ── Section header ── */
  .bento-head {
    max-width: 40rem;
    margin-bottom: 2.75rem;
  }
  .kicker {
    margin: 0 0 0.75rem;
    color: var(--color-coral);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .title {
    margin: 0;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 1000;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }
  .gradient-text {
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .sub {
    margin: 1rem 0 0;
    color: var(--color-text-muted);
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.6;
  }

  /* ── Grid ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(200px, auto);
    gap: 1.1rem;
  }
  .span-2x2 {
    grid-column: span 2;
    grid-row: span 2;
  }
  .span-3 {
    grid-column: span 3;
  }

  /* ── Card base ── */
  .card {
    position: relative;
    /* Grid items default to min-width:auto, so the terminal's long lines would
       force the whole track wider than a phone viewport. Allow shrinking; the
       <pre> scrolls internally instead. */
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 22px;
    background: var(--color-bg-elevated);
    box-shadow: 0 10px 30px -22px var(--color-shadow);
    transform: translate3d(
      calc(var(--px, 0) * var(--depth)),
      calc(var(--py, 0) * var(--depth)),
      0
    );
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .card:hover {
    border-color: color-mix(in srgb, var(--color-text-muted) 45%, var(--color-border));
    box-shadow: 0 24px 50px -28px var(--color-shadow);
  }
  /* Cursor spotlight — --mx/--my are set from JS on mousemove. */
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      340px circle at var(--mx, 50%) var(--my, 50%),
      var(--color-spotlight, rgba(255, 255, 255, 0.07)),
      transparent 65%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .card:hover::after {
    opacity: 1;
  }
  :root {
    --color-spotlight: rgba(43, 37, 23, 0.06);
  }
  [data-theme='dark'] {
    --color-spotlight: rgba(255, 241, 214, 0.07);
  }

  .card h3 {
    margin: 0;
    font-size: 1.18rem;
    font-weight: 900;
    letter-spacing: -0.01em;
  }
  .card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.93rem;
    font-weight: 600;
    line-height: 1.55;
  }
  .card p code {
    padding: 0.1rem 0.35rem;
    border-radius: 6px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    font-size: 0.85em;
  }

  /* Icon tiles */
  .tile {
    position: relative;
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    margin-bottom: 0.35rem;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.35s ease;
  }

  .icon-svg {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.35s ease;
  }

  .card-icon-animated:hover .tile {
    transform: translateY(-2px) scale(1.1);
    box-shadow: 0 0 36px -2px rgba(var(--accent-rgb), 0.55);
  }

  /* ── 1. Smartphone Icon Animation (Android-first) ── */
  .card-icon-animated[data-anim="smartphone"]:hover .icon-svg {
    animation: smartphoneFloat 2.2s ease-in-out infinite alternate;
    filter: drop-shadow(0 0 10px rgba(255, 107, 74, 0.85));
  }
  @keyframes smartphoneFloat {
    0% { transform: translateY(0) rotate(0deg) scale(1); }
    50% { transform: translateY(-3px) rotate(-8deg) scale(1.14); }
    100% { transform: translateY(2px) rotate(8deg) scale(1.08); }
  }

  /* ── 2. Zap Icon Animation (Lynx engine) ── */
  .card-icon-animated[data-anim="zap"]:hover .icon-svg {
    animation: zapPulse 0.85s cubic-bezier(0.36, 0.07, 0.19, 0.97) infinite;
    filter: drop-shadow(0 0 12px rgba(254, 188, 46, 0.95));
  }
  @keyframes zapPulse {
    0% { transform: scale(1) rotate(0deg); }
    20% { transform: scale(1.3) rotate(-14deg) skewX(-6deg); }
    40% { transform: scale(0.92) rotate(10deg); }
    60% { transform: scale(1.22) rotate(-6deg); }
    80% { transform: scale(1.04) rotate(4deg); }
    100% { transform: scale(1) rotate(0deg); }
  }

  /* ── 3. Gauge Icon Animation (Rspeedy builds) ── */
  .card-icon-animated[data-anim="gauge"]:hover .icon-svg {
    filter: drop-shadow(0 0 10px rgba(40, 200, 64, 0.9));
  }
  .card-icon-animated[data-anim="gauge"]:hover .icon-svg path:first-child {
    transform-origin: 12px 14px;
    animation: gaugeNeedle 1.6s cubic-bezier(0.25, 1, 0.5, 1) infinite;
  }
  @keyframes gaugeNeedle {
    0% { transform: rotate(0deg); }
    35% { transform: rotate(180deg); }
    55% { transform: rotate(155deg); }
    100% { transform: rotate(360deg); }
  }

  /* ── 4. Braces Icon Animation (TypeScript strict) ── */
  .card-icon-animated[data-anim="braces"]:hover .icon-svg {
    animation: bracesMorph 1.8s ease-in-out infinite;
    filter: drop-shadow(0 0 12px rgba(64, 169, 255, 0.9));
  }
  @keyframes bracesMorph {
    0% { transform: scaleX(1) scaleY(1); }
    25% { transform: scaleX(1.38) scaleY(0.88); }
    50% { transform: scaleX(0.84) scaleY(1.28); }
    75% { transform: scaleX(1.22) scaleY(0.94); }
    100% { transform: scaleX(1) scaleY(1); }
  }
  .tile-coral {
    color: var(--color-coral);
    background: color-mix(in srgb, var(--color-coral) 14%, transparent);
    box-shadow: 0 0 32px -6px color-mix(in srgb, var(--color-coral) 45%, transparent);
  }
  .tile-amber {
    color: var(--color-amber);
    background: color-mix(in srgb, var(--color-amber) 16%, transparent);
    box-shadow: 0 0 32px -6px color-mix(in srgb, var(--color-amber) 45%, transparent);
  }
  .tile-green {
    color: var(--color-green);
    background: color-mix(in srgb, var(--color-green) 14%, transparent);
    box-shadow: 0 0 32px -6px color-mix(in srgb, var(--color-green) 45%, transparent);
  }
  .tile-blue {
    color: var(--color-blue);
    background: color-mix(in srgb, var(--color-blue) 14%, transparent);
    box-shadow: 0 0 32px -6px color-mix(in srgb, var(--color-blue) 45%, transparent);
  }

  /* ── Terminal card (always dark, like a real terminal) ── */
  .card-terminal {
    background: #16130d;
    border-color: #332d1f;
    padding: 0;
    overflow: hidden;
    gap: 0;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid #2b2619;
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot-coral { background: #ff5f57; box-shadow: 0 0 6px -1px #ff5f57; }
  .dot-amber { background: #febc2e; box-shadow: 0 0 6px -1px #febc2e; }
  .dot-green { background: #28c840; box-shadow: 0 0 6px -1px #28c840; }
  .terminal-title {
    margin-left: 0.5rem;
    color: #6d6449;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .terminal-body {
    margin: 0;
    padding: 1.3rem 1.4rem 1.5rem;
    overflow-x: auto;
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-size: 0.88rem;
    line-height: 1.75;
    color: #a29a85;
  }
  .t-cmd { color: #f5f1e4; }
  .t-dim { color: #6d6449; }
  .t-bold { color: #f5f1e4; font-weight: 700; }
  .t-coral { color: var(--color-coral); }
  .t-amber { color: var(--color-amber); }
  .t-green { color: var(--color-green); }

  /* ── Packages card ── */
  .card-packages {
    gap: 1rem;
  }
  .packages-title {
    margin: 0;
  }
  .packages-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .packages-list li + li {
    border-top: 1px solid var(--color-border);
  }
  .pkg {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.8rem 0.25rem;
    text-decoration: none;
    color: inherit;
  }
  .pkg-chip {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 4px;
    background: var(--pkg-color);
    box-shadow: 0 0 14px -2px var(--pkg-color);
    transition: transform 0.2s ease;
  }
  .pkg:hover .pkg-chip {
    transform: rotate(45deg);
  }
  .pkg-body {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .pkg-name {
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .pkg:hover .pkg-name {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pkg-desc {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pkg-version {
    margin-left: auto;
    flex-shrink: 0;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 700;
  }

  /* ── Open-source card ── */
  .card-oss {
    text-decoration: none;
    color: inherit;
    justify-content: space-between;
    align-items: center;
  }
  .oss-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    color: var(--color-text);
  }
  .oss-arrow {
    color: var(--color-text-muted);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .card-oss:hover .oss-arrow {
    transform: translate(3px, -3px);
    color: var(--color-text);
  }
  .oss-mit {
    font-size: 2.4rem;
    font-weight: 1000;
    letter-spacing: -0.03em;
    text-align: center;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .oss-label {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  /* ── Responsive ── */
  @media (max-width: 1020px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .span-2x2 {
      grid-column: span 2;
    }
    .span-3 {
      grid-column: span 2;
    }
    .card-oss {
      grid-column: span 2;
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }
    .oss-top {
      width: auto;
    }
    .oss-mit {
      font-size: 1.8rem;
    }
  }
  @media (max-width: 620px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .span-2x2,
    .span-3,
    .card-oss {
      grid-column: span 1;
    }
  }
</style>

<script>
  (function () {
    const el = document.getElementById('bento-term-cmd');
    const card = el?.closest('.card-terminal');
    if (!el || !card) return;

    const original = 'cd my-app && jilatax run android';
    const cmds = ['bun run run:android', 'bun run create:aab'];
    let cmdIndex = 0;
    let currentAnimationId = 0;
    const cursor = '█';

    function animateTyping(target: string) {
      const animationId = ++currentAnimationId;
      let current = (el!.textContent || original).replace(cursor, '');
      let isDeleting = current !== '';
      let text = current;

      function nextStep() {
        if (currentAnimationId !== animationId) return;

        if (isDeleting) {
          const delCount = Math.floor(Math.random() * 2) + 1;
          text = text.slice(0, -delCount);
          el!.textContent = text + cursor;

          if (text.length === 0) {
            isDeleting = false;
            setTimeout(nextStep, 180);
          } else {
            setTimeout(nextStep, 25 + Math.random() * 20);
          }
        } else {
          if (text.length === target.length) {
            el!.textContent = target;
            return;
          }

          const trueChar = target[text.length];
          if (Math.random() < 0.25) {
            const glitchChars = '!<>-_/[]{}—=+*^?#';
            const glitch = glitchChars[Math.floor(Math.random() * glitchChars.length)];
            el!.textContent = text + glitch + cursor;
            setTimeout(() => {
              if (currentAnimationId !== animationId) return;
              text += trueChar;
              el!.textContent = text + cursor;
              setTimeout(nextStep, 35 + Math.random() * 45);
            }, 45);
          } else {
            text += trueChar;
            el!.textContent = text + cursor;
            setTimeout(nextStep, 30 + Math.random() * 50);
          }
        }
      }
      nextStep();
    }

    card.addEventListener('mouseenter', () => {
      const target = cmds[cmdIndex % cmds.length];
      cmdIndex++;
      animateTyping(target);
    });

    card.addEventListener('mouseleave', () => {
      animateTyping(original);
    });
  })();
</script>
