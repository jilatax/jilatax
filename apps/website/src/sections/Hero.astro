---
import Marquee from '@/components/Marquee.astro';
import { Check, Copy, Download, TrendingUp, Package } from '@lucide/astro';
import NpmIcon from '@/assets/icons/package-managers/npm.svg';
import YarnIcon from '@/assets/icons/package-managers/yarn.svg';
import PnpmIcon from '@/assets/icons/package-managers/pnpm.svg';
import BunIcon from '@/assets/icons/package-managers/bun.svg';

const packages = ['jilatax', 'create-jilatax', '@jilatax/cli', '@jilatax/svg'];

let weeklyDownloads = 0;
let totalDownloads = 0;

try {
  const results = await Promise.all(
    packages.map(async (p) => {
      try {
        const [wRes, tRes] = await Promise.all([
          fetch(`https://api.npmjs.org/downloads/point/last-week/${p}`).then((r) => r.json()),
          fetch(`https://api.npmjs.org/downloads/point/2024-01-01:2030-01-01/${p}`).then((r) => r.json())
        ]);
        return {
          weekly: wRes.downloads || 0,
          total: tRes.downloads || 0
        };
      } catch {
        return { weekly: 0, total: 0 };
      }
    })
  );

  weeklyDownloads = results.reduce((acc, r) => acc + r.weekly, 0);
  totalDownloads = results.reduce((acc, r) => acc + r.total, 0);
} catch {
  weeklyDownloads = 7617;
  totalDownloads = 7617;
}

if (weeklyDownloads === 0) weeklyDownloads = 7617;
if (totalDownloads === 0) totalDownloads = 7617;

function formatNum(num: number): string {
  if (num >= 1_000_000_000) return (num / 1_000_000_000).toFixed(2) + ' Billion';
  if (num >= 1_000_000) return (num / 1_000_000).toFixed(1) + 'M';
  return new Intl.NumberFormat('en-US').format(num);
}
---

<section class="hero">
  <div class="announcement-banner">
    <div class="banner-content">
      <span class="banner-version">🎉 Jilatax v0.0.1</span>
      <span class="beta-badge">Beta</span>
      <span class="banner-tagline">is officially out! Scaffold production-ready Android apps in seconds.</span>
      <a href="https://docs.jilatax.dev" target="_blank" rel="noopener noreferrer" class="banner-btn">Read the docs &rarr;</a>
    </div>
  </div>

  <div class="hero-inner">
    <div class="hero-copy">

      <h1 class="title">
        One command.<br />
        Zero config.<br />
        <span class="gradient-text">Ship Android apps.</span>
      </h1>

      <p class="sub">
        Jilatax is the Android-first application framework for <strong>Lynx</strong> and <strong>Rspeedy</strong>. Scaffold a production-ready project in seconds — the CLI wires up the rest.
      </p>

      <div class="cmd-box" role="group" aria-label="Install command">
        <div class="cmd-topbar">
          <div class="cmd-tabs">
            <button class="cmd-tab" data-pm="npm">
              <NpmIcon width={14} height={14} aria-hidden="true" /> npm
            </button>
            <button class="cmd-tab" data-pm="yarn">
              <YarnIcon width={14} height={14} aria-hidden="true" /> yarn
            </button>
            <button class="cmd-tab" data-pm="pnpm">
              <PnpmIcon width={14} height={14} aria-hidden="true" /> pnpm
            </button>
            <button class="cmd-tab active" data-pm="bun">
              <BunIcon width={18} height={18} aria-hidden="true" /> bun
            </button>
          </div>
        </div>
        <div class="cmd-content">
          <code class="cmd-text">
            <span class="hl-dollar">$</span>
            <span class="hl-pm">bun</span> <span class="hl-cmd">create jilatax@latest</span>
          </code>
          <button class="cmd-copy" type="button" data-copy="bun create jilatax@latest" aria-label="Copy install command">
            <Copy class="icon-copy" size={16} aria-hidden="true" />
            <Check class="icon-check" size={16} aria-hidden="true" />
          </button>
        </div>
      </div>



      <hr class="divider" />

      <div class="tanstack-stats">
        <div class="ts-card">
          <div class="ts-card-bar emerald"></div>
          <div class="ts-card-body">
            <Download class="ts-card-icon emerald" size={22} />
            <div class="ts-card-info">
              <span class="ts-card-value">{formatNum(totalDownloads)}</span>
              <span class="ts-card-label">Total NPM Downloads</span>
            </div>
          </div>
        </div>

        <div class="ts-card">
          <div class="ts-card-bar cyan"></div>
          <div class="ts-card-body">
            <TrendingUp class="ts-card-icon cyan" size={22} />
            <div class="ts-card-info">
              <span class="ts-card-value">{formatNum(weeklyDownloads)}</span>
              <span class="ts-card-label">Weekly Downloads</span>
            </div>
          </div>
        </div>

        <div class="ts-card">
          <div class="ts-card-bar amber"></div>
          <div class="ts-card-body">
            <Package class="ts-card-icon amber" size={22} />
            <div class="ts-card-info">
              <span class="ts-card-value">{packages.length}</span>
              <span class="ts-card-label">NPM Packages</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="marquee-wrapper">
    <Marquee />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow-x: clip;
    overflow-y: visible;
  }
  .marquee-wrapper {
    position: absolute;
    bottom: -3rem;
    left: -2%;
    width: 104%;
    transform: rotate(-2deg);
    z-index: 0;
  }
  .hero-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 800px;
  }

  /* ── Announcement Banner ── */
  .announcement-banner {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-notice-bg);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-notice-text);
  }
  .banner-content {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
    text-align: center;
    max-width: 100%;
  }
  .banner-version {
    white-space: nowrap;
  }
  .beta-badge {
    background: #c0c0c0; /* Silver bg */
    color: #110f0b; /* Dark text for contrast */
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    letter-spacing: 0.05em;
    line-height: 1;
    white-space: nowrap;
  }
  .banner-tagline {
    opacity: 0.95;
  }
  .announcement-banner .banner-btn {
    color: var(--color-coral);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 600;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .announcement-banner .banner-btn:hover {
    color: var(--color-orange);
  }

  @media (max-width: 640px) {
    .banner-tagline {
      display: none;
    }
  }

  .title {
    margin: 0;
    font-size: clamp(2.7rem, 6vw, 4.4rem);
    font-weight: 1000;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .gradient-text {
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .sub {
    margin: 1.4rem auto 0;
    max-width: 34rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.65;
  }
  .sub strong {
    color: var(--color-text);
  }

  /* ── Command Box ── */
  .cmd-box {
    margin-top: 2.1rem;
    display: flex;
    flex-direction: column;
    max-width: 100%;
    width: 520px;
    border-radius: 12px;
    border: 1px solid #332d1f;
    background: #17140e;
    box-shadow: 0 18px 45px -18px rgba(0, 0, 0, 0.55);
    overflow: hidden;
    text-align: left;
  }
  .cmd-topbar {
    display: flex;
    align-items: center;
    padding: 0.6rem 1rem;
    background: #1d1a12;
    border-bottom: 1px solid #332d1f;
  }

  .cmd-tabs {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cmd-tabs::-webkit-scrollbar {
    display: none;
  }
  .cmd-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: #a29a85;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .cmd-tab:hover {
    color: #f5f1e4;
    background: rgba(245, 241, 228, 0.05);
  }
  .cmd-tab.active {
    background: rgba(245, 241, 228, 0.1);
    color: #f5f1e4;
  }
  
  .cmd-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: #17140e;
  }
  .cmd-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-size: 0.95rem;
    white-space: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
    color: #f5f1e4;
  }
  .cmd-text::-webkit-scrollbar {
    display: none;
  }
  .hl-dollar {
    color: #a29a85;
    user-select: none;
  }
  .hl-pm {
    color: #38bdf8;
  }
  .hl-cmd {
    color: #34d399;
  }
  .cmd-copy {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid #332d1f;
    border-radius: 8px;
    background: transparent;
    color: #a29a85;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-left: 1rem;
  }
  .cmd-copy:hover {
    color: #f5f1e4;
    border-color: #a29a85;
    background: rgba(245, 241, 228, 0.05);
  }
  .cmd-copy .icon-check {
    display: none;
    color: #34d399;
  }
  .cmd-copy.copied .icon-copy {
    display: none;
  }
  .cmd-copy.copied .icon-check {
    display: block;
  }



  /* ── TanStack Style Stats ── */
  .divider {
    margin: 2.5rem 0 2rem;
    border: 0;
    border-top: 1.5px dashed var(--color-border);
    width: 100%;
  }
  .tanstack-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 860px;
  }
  .ts-card {
    position: relative;
    display: flex;
    align-items: center;
    background: #17140e;
    border: 1px solid #332d1f;
    border-radius: 12px;
    padding: 0.85rem 1rem 0.85rem 1.2rem;
    box-shadow: 0 12px 30px -10px rgba(0, 0, 0, 0.45);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
    min-width: 0;
  }
  .ts-card:hover {
    transform: translateY(-2px);
    border-color: #524734;
    box-shadow: 0 16px 36px -12px rgba(0, 0, 0, 0.65);
  }
  .ts-card-bar {
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 3.5px;
    border-radius: 4px;
  }
  .ts-card-bar.emerald {
    background: #10b981;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.6);
  }
  .ts-card-bar.cyan {
    background: #06b6d4;
    box-shadow: 0 0 10px rgba(6, 182, 212, 0.6);
  }
  .ts-card-bar.amber {
    background: #f59e0b;
    box-shadow: 0 0 10px rgba(245, 158, 11, 0.6);
  }
  .ts-card-body {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-align: left;
    min-width: 0;
  }
  .ts-card-icon {
    flex-shrink: 0;
  }
  .ts-card-icon.emerald { color: #10b981; }
  .ts-card-icon.cyan { color: #06b6d4; }
  .ts-card-icon.amber { color: #f59e0b; }
  
  .ts-card-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .ts-card-value {
    font-size: 1.35rem;
    font-weight: 850;
    color: #f5f1e4;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-family: inherit;
    white-space: nowrap;
  }
  .ts-card-label {
    font-size: 0.78rem;
    font-style: italic;
    font-weight: 500;
    color: #a29a85;
    margin-top: 0.2rem;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .tanstack-stats {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      justify-content: flex-start;
      padding-bottom: 0.5rem;
    }
    .tanstack-stats::-webkit-scrollbar {
      display: none;
    }
    .ts-card {
      flex: 0 0 auto;
      min-width: 190px;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner {
      padding-top: 3rem;
    }
  }
  @media (max-width: 520px) {
    .stats {
      gap: 1.5rem;
    }
    .cmd-text {
      font-size: 0.85rem;
    }
    .cmd-tab {
      padding: 0.3rem 0.5rem;
      font-size: 0.8rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-dot {
      animation: none;
    }
  }
</style>

<script>
  const box = document.querySelector('.cmd-box');
  if (box) {
    const tabs = box.querySelectorAll('.cmd-tab') as NodeListOf<HTMLElement>;
    const pmText = box.querySelector('.hl-pm');
    const copyBtn = box.querySelector('.cmd-copy') as HTMLElement | null;
    const cmdBase = 'create jilatax@latest';

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        
        const pm = tab.dataset.pm;
        if (pmText) pmText.textContent = pm || '';
        
        const newCmd = `${pm} ${cmdBase}`;
        if (copyBtn) copyBtn.dataset.copy = newCmd;
      });
    });

    copyBtn?.addEventListener('click', async () => {
      try {
        const textToCopy = copyBtn.dataset.copy || '';
        await navigator.clipboard.writeText(textToCopy);
        copyBtn.classList.add('copied');
        setTimeout(() => copyBtn.classList.remove('copied'), 2000);
      } catch (err) {
        console.error('Failed to copy', err);
      }
    });
  }
</script>
