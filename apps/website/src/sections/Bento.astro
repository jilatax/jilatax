---
import { ArrowUpRight, Braces, Gauge, Smartphone, Zap } from '@lucide/astro';
import GithubIcon from '@/assets/icons/social/github.svg';
import { LINKS } from '@/consts';

// The three published packages (npm registry, image 3 of the brief).
const packages = [
  {
    name: 'jilatax',
    version: '0.0.5',
    description: 'Android-first application framework for Lynx and Rspeedy.',
    color: 'var(--color-coral)',
    href: 'https://www.npmjs.com/package/jilatax',
  },
  {
    name: 'create-jilatax',
    version: '0.0.5',
    description: 'Create an Android-first Jilatax application for Lynx and Rspeedy.',
    color: 'var(--color-amber)',
    href: 'https://www.npmjs.com/package/create-jilatax',
  },
  {
    name: '@jilatax/cli',
    version: '0.0.8',
    description: 'Android build and device orchestration for Jilatax applications.',
    color: 'var(--color-blue)',
    href: 'https://www.npmjs.com/package/@jilatax/cli',
  },
];
---

<section class="bento" id="box">
  <header class="bento-head">
    <p class="kicker">The bento box</p>
    <h2 class="title">Everything you need, <span class="gradient-text">packed tight.</span></h2>
    <p class="sub">
      Framework, scaffolder and CLI — three packages that take you from an empty
      folder to a running Android app.
    </p>
  </header>

  <div class="grid">
    <!-- Terminal: the create flow -->
    <article class="card card-terminal span-2x2" style="--depth: 5px" data-spotlight>
      <div class="terminal-bar">
        <span class="dot dot-coral"></span>
        <span class="dot dot-amber"></span>
        <span class="dot dot-green"></span>
        <span class="terminal-title">terminal</span>
      </div>
      <pre class="terminal-body"><code><span class="t-dim">$</span> <span class="t-cmd">npm create jilatax@latest</span>

<span class="t-coral">┌</span>  <span class="t-bold">create-jilatax</span>  <span class="t-dim">v0.0.5</span>
<span class="t-coral">│</span>
<span class="t-green">◇</span>  Project name?
<span class="t-coral">│</span>  <span class="t-cmd">my-app</span>
<span class="t-coral">│</span>
<span class="t-green">◇</span>  Template
<span class="t-coral">│</span>  <span class="t-cmd">Lynx + Rspeedy</span> <span class="t-dim">· Android</span>
<span class="t-coral">│</span>
<span class="t-amber">└</span>  <span class="t-green">Ready!</span>  <span class="t-dim">cd my-app &&amp; jilatax run android</span></code></pre>
    </article>

    <!-- Android-first -->
    <article class="card" style="--depth: 12px" data-spotlight>
      <span class="tile tile-coral"><Smartphone size={22} aria-hidden="true" /></span>
      <h3>Android-first</h3>
      <p>A native Gradle project lands in <code>./android</code> — manifests, flavors and device orchestration wired up for you.</p>
    </article>

    <!-- Lynx -->
    <article class="card" style="--depth: 16px" data-spotlight>
      <span class="tile tile-amber"><Zap size={22} aria-hidden="true" /></span>
      <h3>Lynx engine</h3>
      <p>Dual-threaded UI with instant first paint. Write once in TypeScript, render truly native views.</p>
    </article>

    <!-- Rspeedy -->
    <article class="card" style="--depth: 14px" data-spotlight>
      <span class="tile tile-green"><Gauge size={22} aria-hidden="true" /></span>
      <h3>Rspeedy builds</h3>
      <p>Rspack-powered bundling with sub-second HMR while you iterate on a real device.</p>
    </article>

    <!-- TypeScript -->
    <article class="card" style="--depth: 18px" data-spotlight>
      <span class="tile tile-blue"><Braces size={22} aria-hidden="true" /></span>
      <h3>TypeScript strict</h3>
      <p>Typed APIs end to end, plus a JSON-schema-validated app config out of the box.</p>
    </article>

    <!-- Packages -->
    <article class="card card-packages span-3" id="packages" style="--depth: 4px" data-spotlight>
      <h3 class="packages-title">Three packages, one toolbox</h3>
      <ul class="packages-list">
        {packages.map((pkg) => (
          <li>
            <a class="pkg" href={pkg.href} target="_blank" rel="noopener noreferrer">
              <span class="pkg-chip" style={`--pkg-color: ${pkg.color}`}></span>
              <span class="pkg-body">
                <span class="pkg-name">{pkg.name}</span>
                <span class="pkg-desc">{pkg.description}</span>
              </span>
              <span class="pkg-version">v{pkg.version}</span>
            </a>
          </li>
        ))}
      </ul>
    </article>

    <!-- Open source -->
    <a class="card card-oss" href={LINKS.github} target="_blank" rel="noopener noreferrer" style="--depth: 10px" data-spotlight>
      <span class="oss-top">
        <GithubIcon width={22} height={22} aria-hidden="true" />
        <ArrowUpRight size={18} aria-hidden="true" class="oss-arrow" />
      </span>
      <span class="oss-mit">MIT</span>
      <span class="oss-label">Open source, forever.</span>
    </a>
  </div>
</section>

<style>
  .bento {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4.5rem;
  }

  /* ── Section header ── */
  .bento-head {
    max-width: 40rem;
    margin-bottom: 2.75rem;
  }
  .kicker {
    margin: 0 0 0.75rem;
    color: var(--color-coral);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .title {
    margin: 0;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 1000;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }
  .gradient-text {
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .sub {
    margin: 1rem 0 0;
    color: var(--color-text-muted);
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.6;
  }

  /* ── Grid ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(200px, auto);
    gap: 1.1rem;
  }
  .span-2x2 {
    grid-column: span 2;
    grid-row: span 2;
  }
  .span-3 {
    grid-column: span 3;
  }

  /* ── Card base ── */
  .card {
    position: relative;
    /* Grid items default to min-width:auto, so the terminal's long lines would
       force the whole track wider than a phone viewport. Allow shrinking; the
       <pre> scrolls internally instead. */
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 22px;
    background: var(--color-bg-elevated);
    box-shadow: 0 10px 30px -22px var(--color-shadow);
    transform: translate3d(
      calc(var(--px, 0) * var(--depth)),
      calc(var(--py, 0) * var(--depth)),
      0
    );
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .card:hover {
    border-color: color-mix(in srgb, var(--color-text-muted) 45%, var(--color-border));
    box-shadow: 0 24px 50px -28px var(--color-shadow);
  }
  /* Cursor spotlight — --mx/--my are set from JS on mousemove. */
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      340px circle at var(--mx, 50%) var(--my, 50%),
      var(--color-spotlight, rgba(255, 255, 255, 0.07)),
      transparent 65%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .card:hover::after {
    opacity: 1;
  }
  :root {
    --color-spotlight: rgba(43, 37, 23, 0.06);
  }
  [data-theme='dark'] {
    --color-spotlight: rgba(255, 241, 214, 0.07);
  }

  .card h3 {
    margin: 0;
    font-size: 1.18rem;
    font-weight: 900;
    letter-spacing: -0.01em;
  }
  .card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.93rem;
    font-weight: 600;
    line-height: 1.55;
  }
  .card p code {
    padding: 0.1rem 0.35rem;
    border-radius: 6px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    font-size: 0.85em;
  }

  /* Icon tiles */
  .tile {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    margin-bottom: 0.35rem;
  }
  .tile-coral {
    color: var(--color-coral);
    background: color-mix(in srgb, var(--color-coral) 14%, transparent);
    box-shadow: 0 0 32px -6px color-mix(in srgb, var(--color-coral) 45%, transparent);
  }
  .tile-amber {
    color: var(--color-amber);
    background: color-mix(in srgb, var(--color-amber) 16%, transparent);
    box-shadow: 0 0 32px -6px color-mix(in srgb, var(--color-amber) 45%, transparent);
  }
  .tile-green {
    color: var(--color-green);
    background: color-mix(in srgb, var(--color-green) 14%, transparent);
    box-shadow: 0 0 32px -6px color-mix(in srgb, var(--color-green) 45%, transparent);
  }
  .tile-blue {
    color: var(--color-blue);
    background: color-mix(in srgb, var(--color-blue) 14%, transparent);
    box-shadow: 0 0 32px -6px color-mix(in srgb, var(--color-blue) 45%, transparent);
  }

  /* ── Terminal card (always dark, like a real terminal) ── */
  .card-terminal {
    background: #16130d;
    border-color: #332d1f;
    padding: 0;
    overflow: hidden;
    gap: 0;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid #2b2619;
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot-coral { background: var(--color-coral); }
  .dot-amber { background: var(--color-amber); }
  .dot-green { background: var(--color-green); }
  .terminal-title {
    margin-left: 0.5rem;
    color: #6d6449;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .terminal-body {
    margin: 0;
    padding: 1.3rem 1.4rem 1.5rem;
    overflow-x: auto;
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-size: 0.88rem;
    line-height: 1.75;
    color: #a29a85;
  }
  .t-cmd { color: #f5f1e4; }
  .t-dim { color: #6d6449; }
  .t-bold { color: #f5f1e4; font-weight: 700; }
  .t-coral { color: var(--color-coral); }
  .t-amber { color: var(--color-amber); }
  .t-green { color: var(--color-green); }

  /* ── Packages card ── */
  .card-packages {
    gap: 1rem;
  }
  .packages-title {
    margin: 0;
  }
  .packages-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .packages-list li + li {
    border-top: 1px solid var(--color-border);
  }
  .pkg {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.8rem 0.25rem;
    text-decoration: none;
    color: inherit;
  }
  .pkg-chip {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 4px;
    background: var(--pkg-color);
    box-shadow: 0 0 14px -2px var(--pkg-color);
    transition: transform 0.2s ease;
  }
  .pkg:hover .pkg-chip {
    transform: rotate(45deg);
  }
  .pkg-body {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .pkg-name {
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .pkg:hover .pkg-name {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pkg-desc {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pkg-version {
    margin-left: auto;
    flex-shrink: 0;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 700;
  }

  /* ── Open-source card ── */
  .card-oss {
    text-decoration: none;
    color: inherit;
    justify-content: space-between;
  }
  .oss-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--color-text);
  }
  .oss-arrow {
    color: var(--color-text-muted);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .card-oss:hover .oss-arrow {
    transform: translate(3px, -3px);
    color: var(--color-text);
  }
  .oss-mit {
    font-size: 2.4rem;
    font-weight: 1000;
    letter-spacing: -0.03em;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .oss-label {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  /* ── Responsive ── */
  @media (max-width: 1020px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .span-2x2 {
      grid-column: span 2;
    }
    .span-3 {
      grid-column: span 2;
    }
    .card-oss {
      grid-column: span 2;
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }
    .oss-mit {
      font-size: 1.8rem;
    }
  }
  @media (max-width: 620px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .span-2x2,
    .span-3,
    .card-oss {
      grid-column: span 1;
    }
  }
</style>
