---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/sections/Hero.astro';
import Bento from '@/sections/Bento.astro';
import Marquee from '@/sections/Marquee.astro';
---

<Layout>
  <Hero />
  <Bento />
  <Marquee />
</Layout>

<script is:inline>
  // Landing-page interactions. Guarded so View Transitions never double-bind:
  // the listeners and the rAF loop live for the whole session, only the DOM
  // they read is swapped.
  (function () {
    if (window.__jlx) return;
    window.__jlx = true;

    // ── Mouse parallax ──
    // Elements opt in via `--depth` and read the global --px/--py (lerped
    // -1..1) in their CSS transform, so one write per frame moves everything.
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let tx = 0;
      let ty = 0;
      let cx = 0;
      let cy = 0;

      addEventListener(
        'mousemove',
        (e) => {
          tx = (e.clientX / innerWidth) * 2 - 1;
          ty = (e.clientY / innerHeight) * 2 - 1;
        },
        { passive: true },
      );

      (function tick() {
        cx += (tx - cx) * 0.055;
        cy += (ty - cy) * 0.055;
        const style = document.documentElement.style;
        style.setProperty('--px', cx.toFixed(4));
        style.setProperty('--py', cy.toFixed(4));
        requestAnimationFrame(tick);
      })();
    }

    // ── Card spotlight ──
    addEventListener(
      'mousemove',
      (e) => {
        const card = e.target && e.target.closest ? e.target.closest('[data-spotlight]') : null;
        if (!card) return;
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        card.style.setProperty('--my', `${e.clientY - rect.top}px`);
      },
      { passive: true },
    );

    // ── Copy install command ──
    addEventListener('click', async (e) => {
      const btn = e.target && e.target.closest ? e.target.closest('[data-copy]') : null;
      if (!btn) return;
      try {
        await navigator.clipboard.writeText(btn.dataset.copy);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1600);
      } catch {
        // Clipboard unavailable (non-secure context) — leave the icon as-is.
      }
    });
  })();
</script>
