---
import Marquee from '@/components/Marquee.astro';
import { Check, Copy, Download, TrendingUp, Package } from '@lucide/astro';
import NpmIcon from '@/assets/icons/package-managers/npm.svg';
import YarnIcon from '@/assets/icons/package-managers/yarn.svg';
import PnpmIcon from '@/assets/icons/package-managers/pnpm.svg';
import BunIcon from '@/assets/icons/package-managers/bun.svg';
import { getNpmStats } from '@/lib/npm-stats';

const npmStats = await getNpmStats();
const { weeklyDownloads, totalDownloads, packageCount, weeklyUpdatedAt } = npmStats;

function formatNum(num: number): string {
  if (num >= 1_000_000_000) return (num / 1_000_000_000).toFixed(2) + ' Billion';
  if (num >= 1_000_000) return (num / 1_000_000).toFixed(1) + 'M';
  return new Intl.NumberFormat('en-US').format(num);
}
---

<section class="hero">
  <div class="announcement-banner">
    <div class="banner-content">
      <span class="banner-version">🎉 Jilatax v0.0.1</span>
      <span class="beta-badge">Beta</span>
      <span class="banner-tagline">is officially out! Scaffold production-ready Android apps in seconds.</span>
      <a href="https://docs.jilatax.dev" target="_blank" rel="noopener noreferrer" class="banner-btn">Read the docs &rarr;</a>
    </div>
  </div>

  <div class="hero-inner">
    <div class="hero-copy">

      <h1 class="title">
        One command.<br />
        Zero config.<br />
        <span class="gradient-text">Ship <span class="android-typography">Android</span> apps.</span>
      </h1>

      <p class="sub">
        Jilatax is the Android-first application framework for <strong>Lynx</strong> and <strong>Rspeedy</strong>. Scaffold a production-ready project in seconds — the CLI wires up the rest.
      </p>

      <div class="cmd-box" role="group" aria-label="Install command">
        <div class="cmd-topbar">
          <div class="cmd-tabs">
            <button class="cmd-tab" data-pm="npm">
              <NpmIcon width={14} height={14} aria-hidden="true" /> npm
            </button>
            <button class="cmd-tab" data-pm="yarn">
              <YarnIcon width={14} height={14} aria-hidden="true" /> yarn
            </button>
            <button class="cmd-tab" data-pm="pnpm">
              <PnpmIcon width={14} height={14} aria-hidden="true" /> pnpm
            </button>
            <button class="cmd-tab active" data-pm="bun">
              <BunIcon width={18} height={18} aria-hidden="true" /> bun
            </button>
          </div>
        </div>
        <div class="cmd-content">
          <code class="cmd-text">
            <span class="hl-dollar">$</span>
            <span class="hl-pm">bun</span> <span class="hl-cmd">create jilatax@latest</span>
          </code>
          <button class="cmd-copy" type="button" data-copy="bun create jilatax@latest" aria-label="Copy install command">
            <Copy class="icon-copy" size={16} aria-hidden="true" />
            <Check class="icon-check" size={16} aria-hidden="true" />
          </button>
        </div>
      </div>

      <hr class="divider" />

      <div class="tanstack-stats">
        <div class="ts-card">
          <div class="ts-card-bar emerald"></div>
          <div class="ts-card-body">
            <Download class="ts-card-icon emerald" size={22} />
            <div class="ts-card-info">
              <span class="ts-card-value">{formatNum(totalDownloads)}</span>
              <span class="ts-card-label">Total NPM Downloads</span>
            </div>
          </div>
        </div>

        <div class="ts-card">
          <div class="ts-card-bar cyan"></div>
          <div class="ts-card-body">
            <TrendingUp class="ts-card-icon cyan" size={22} />
            <div class="ts-card-info">
              <span
                class="ts-card-value"
                data-weekly-downloads
                data-target={weeklyDownloads}
                data-updated-at={weeklyUpdatedAt}
                title="Live estimate based on the latest npm weekly snapshot"
              >{formatNum(weeklyDownloads)}</span>
              <span class="ts-card-label"><span class="live-dot" aria-hidden="true"></span>Weekly Downloads</span>
            </div>
          </div>
        </div>

        <div class="ts-card">
          <div class="ts-card-bar amber"></div>
          <div class="ts-card-body">
            <Package class="ts-card-icon amber" size={22} />
            <div class="ts-card-info">
              <span class="ts-card-value">{packageCount}</span>
              <span class="ts-card-label">NPM Packages</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="marquee-wrapper">
    <Marquee />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow-x: clip;
    overflow-y: visible;
  }
  .marquee-wrapper {
    position: absolute;
    bottom: -1rem;
    left: -2%;
    width: 104%;
    transform: rotate(-2deg);
    z-index: 2;
  }
  .hero-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 7.8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 800px;
  }

  /* ── Announcement Banner ── */
  .announcement-banner {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-notice-bg);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-notice-text);
  }
  .banner-content {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
    text-align: center;
    max-width: 100%;
  }
  .banner-version {
    white-space: nowrap;
  }
  .beta-badge {
    background: #c0c0c0; /* Silver bg */
    color: #110f0b; /* Dark text for contrast */
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    letter-spacing: 0.05em;
    line-height: 1;
    white-space: nowrap;
  }
  .banner-tagline {
    opacity: 0.95;
  }
  .announcement-banner .banner-btn {
    color: var(--color-coral);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 600;
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .announcement-banner .banner-btn:hover {
    color: var(--color-orange);
  }

  @media (max-width: 640px) {
    .banner-tagline {
      display: none;
    }
  }

  /* ── Hero Title ── */
  .title {
    margin: 0;
    font-size: clamp(2.7rem, 6vw, 4.4rem);
    font-weight: 1000;
    line-height: 1.04;
    letter-spacing: -0.02em;
    cursor: default;
  }

  .gradient-text {
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Pure inline typography — zero vertical offset, zero background box */
  .android-typography {
    display: inline;
    background: linear-gradient(
      110deg,
      #10b981 0%,
      #14b8a6 20%,
      #06b6d4 40%,
      #ffffff 50%,
      #06b6d4 60%,
      #14b8a6 80%,
      #10b981 100%
    );
    background-size: 220% 100%;
    background-position: 0% 0%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: android-light-sweep 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) 1;
    transition: filter 0.3s ease;
  }

  @media (hover: hover) {
    .title:hover .android-typography {
      animation: android-light-sweep 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) 1;
      filter: drop-shadow(0 0 8px rgba(16, 185, 129, 0.55));
    }
  }

  @media (max-width: 640px) {
    .title:hover .android-typography,
    .android-typography {
      animation: none !important;
      filter: none !important;
    }
  }

  @keyframes android-light-sweep {
    0% {
      background-position: 220% 0%;
    }
    100% {
      background-position: -220% 0%;
    }
  }

  .sub {
    margin: 1.4rem auto 0;
    max-width: 34rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.65;
  }
  .sub strong {
    color: var(--color-text);
  }

  /* ── Command Box ── */
  .cmd-box {
    margin-top: 2.1rem;
    display: flex;
    flex-direction: column;
    max-width: 100%;
    width: 520px;
    border-radius: 12px;
    border: 1px solid #332d1f;
    background: #17140e;
    box-shadow: 0 18px 45px -18px rgba(0, 0, 0, 0.55);
    overflow: hidden;
    text-align: left;
  }
  .cmd-topbar {
    display: flex;
    align-items: center;
    padding: 0.6rem 1rem;
    background: #1d1a12;
    border-bottom: 1px solid #332d1f;
  }

  .cmd-tabs {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cmd-tabs::-webkit-scrollbar {
    display: none;
  }
  .cmd-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: #a29a85;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .cmd-tab:hover {
    color: #f5f1e4;
    background: rgba(245, 241, 228, 0.05);
  }
  .cmd-tab.active {
    background: rgba(245, 241, 228, 0.1);
    color: #f5f1e4;
  }
  
  .cmd-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: #17140e;
  }
  .cmd-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-size: 0.95rem;
    white-space: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
    color: #f5f1e4;
  }
  .cmd-text::-webkit-scrollbar {
    display: none;
  }
  .hl-dollar {
    color: #a29a85;
    user-select: none;
  }
  .hl-pm {
    color: #38bdf8;
  }
  .hl-cmd {
    color: #34d399;
  }
  .cmd-copy {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid #332d1f;
    border-radius: 8px;
    background: transparent;
    color: #a29a85;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-left: 1rem;
  }
  .cmd-copy:hover {
    color: #f5f1e4;
    border-color: #a29a85;
    background: rgba(245, 241, 228, 0.05);
  }
  .cmd-copy .icon-check {
    display: none;
    color: #34d399;
  }
  .cmd-copy.copied .icon-copy {
    display: none;
  }
  .cmd-copy.copied .icon-check {
    display: block;
  }

  /* ── TanStack Style Stats ── */
  .divider {
    margin: 2.5rem 0 2rem;
    border: 0;
    border-top: 1.5px dashed var(--color-border);
    width: 100%;
  }
  .tanstack-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 860px;
  }
  .ts-card {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 0.85rem 1rem 0.85rem 1.2rem;
    box-shadow: 0 12px 30px -10px var(--color-shadow);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
    min-width: 0;
  }
  :global([data-theme='dark']) .ts-card {
    background: #17140e;
  }
  .ts-card:hover {
    transform: translateY(-2px);
    border-color: transparent;
    box-shadow: 0 16px 36px -12px rgba(0, 0, 0, 0.65);
  }
  .ts-card-bar {
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 3.5px;
    border-radius: 4px;
  }
  .ts-card-bar.emerald {
    background: #10b981;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.6);
  }
  .ts-card-bar.cyan {
    background: #06b6d4;
    box-shadow: 0 0 10px rgba(6, 182, 212, 0.6);
  }
  .ts-card-bar.amber {
    background: #f59e0b;
    box-shadow: 0 0 10px rgba(245, 158, 11, 0.6);
  }
  .ts-card-body {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-align: left;
    min-width: 0;
    width: 100%;
  }
  .ts-card-icon {
    flex-shrink: 0;
  }
  .ts-card-icon.emerald { color: #10b981; }
  .ts-card-icon.cyan { color: #06b6d4; }
  .ts-card-icon.amber { color: #f59e0b; }
  
  .ts-card-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .ts-card-value {
    font-size: 1.35rem;
    font-weight: 850;
    color: var(--color-text);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-family: inherit;
    white-space: nowrap;
  }
  .ts-card-label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-style: italic;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
    white-space: nowrap;
  }
  .live-dot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: #06b6d4;
    box-shadow: 0 0 0 rgba(6, 182, 212, 0.55);
    animation: live-pulse 2.4s ease-out infinite;
  }

  @keyframes live-pulse {
    0% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.55); }
    65%, 100% { box-shadow: 0 0 0 0.35rem rgba(6, 182, 212, 0); }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner {
      padding-top: 3rem;
    }
  }

  @media (max-width: 640px) {
    .tanstack-stats {
      grid-template-columns: 1fr 1fr;
      gap: 0.65rem;
    }
    .ts-card {
      padding: 0.75rem 0.6rem 0.75rem 0.95rem;
    }
    .ts-card:nth-child(3) {
      grid-column: 1 / -1;
    }
    .ts-card-body {
      gap: 0.5rem;
    }
    .ts-card-value {
      font-size: 1.18rem;
    }
    .ts-card-label {
      font-size: 0.73rem;
      white-space: normal;
      line-height: 1.25;
    }
  }

  @media (max-width: 480px) {
    .cmd-text {
      font-size: 0.85rem;
    }
    .cmd-tab {
      padding: 0.3rem 0.5rem;
      font-size: 0.8rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-dot {
      animation: none;
    }
    .title:hover .android-typography {
      animation: none;
    }
  }
</style>

<script>
  // ── Package Manager Tabs & Copy ──
  const box = document.querySelector('.cmd-box');
  if (box) {
    const tabs = box.querySelectorAll('.cmd-tab') as NodeListOf<HTMLElement>;
    const pmText = box.querySelector('.hl-pm');
    const copyBtn = box.querySelector('.cmd-copy') as HTMLElement | null;
    const cmdBase = 'create jilatax@latest';

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        
        const pm = tab.dataset.pm;
        if (pmText) pmText.textContent = pm || '';
        
        const newCmd = `${pm} ${cmdBase}`;
        if (copyBtn) copyBtn.dataset.copy = newCmd;
      });
    });

    copyBtn?.addEventListener('click', async () => {
      try {
        const textToCopy = copyBtn.dataset.copy || '';
        await navigator.clipboard.writeText(textToCopy);
        copyBtn.classList.add('copied');
        setTimeout(() => copyBtn.classList.remove('copied'), 2000);
      } catch (err) {
        console.error('Failed to copy', err);
      }
    });
  }

  // ── Weekly Download Estimate ──
  const weeklyValue = document.querySelector('[data-weekly-downloads]') as HTMLElement | null;
  if (weeklyValue) {
    const weeklyElement = weeklyValue;
    const storageKey = 'jilatax:weekly-downloads:v1';
    const weekMs = 7 * 24 * 60 * 60 * 1000;
    const maxProjectionMs = 12 * 60 * 60 * 1000;
    let baseline = Number(weeklyElement.dataset.target || 0);
    let baselineAt = Date.parse(weeklyElement.dataset.updatedAt || '');

    function formatNumberDisplay(num: number): string {
      if (num >= 1_000_000_000) return (num / 1_000_000_000).toFixed(2) + ' Billion';
      if (num >= 1_000_000) return (num / 1_000_000).toFixed(1) + 'M';
      return new Intl.NumberFormat('en-US').format(Math.floor(num));
    }

    function projectedValue(now = Date.now()): number {
      if (!baseline || !Number.isFinite(baselineAt)) return baseline;
      const elapsed = Math.min(Math.max(now - baselineAt, 0), maxProjectionMs);
      return baseline + (baseline / weekMs) * elapsed;
    }

    function render(value: number, persist = true) {
      const rounded = Math.floor(value);
      weeklyElement.textContent = formatNumberDisplay(rounded);
      if (!persist) return;

      try {
        sessionStorage.setItem(storageKey, JSON.stringify({
          value: rounded,
          snapshotAt: new Date(baselineAt).toISOString(),
        }));
      } catch {
        // Storage can be unavailable in privacy-restricted browser contexts.
      }
    }

    function restoreSessionValue(projectIfMissing = true, persistIfMissing = true) {
      try {
        const stored = JSON.parse(sessionStorage.getItem(storageKey) || 'null');
        const snapshotAt = new Date(baselineAt).toISOString();
        if (stored?.snapshotAt === snapshotAt && Number.isFinite(stored.value)) {
          render(Math.max(stored.value, projectedValue()));
          return;
        }
      } catch {
      }

      render(projectIfMissing ? projectedValue() : baseline, persistIfMissing);
    }

    function applySnapshot(stats: { weeklyDownloads: number; weeklyUpdatedAt: string }) {
      if (!Number.isFinite(stats.weeklyDownloads) || !Date.parse(stats.weeklyUpdatedAt)) return;
      baseline = stats.weeklyDownloads;
      baselineAt = Date.parse(stats.weeklyUpdatedAt);
      weeklyElement.dataset.target = String(baseline);
      weeklyElement.dataset.updatedAt = stats.weeklyUpdatedAt;
      restoreSessionValue();
    }

    restoreSessionValue(false, false);

    fetch('/api/npm-stats', { headers: { Accept: 'application/json' } })
      .then((response) => response.ok ? response.json() : Promise.reject())
      .then(applySnapshot)
      .catch(() => restoreSessionValue())
      .finally(() => setInterval(() => render(projectedValue()), 1000));
  }
</script>
