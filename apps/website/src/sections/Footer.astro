---
import { SITE, LINKS } from '@/consts';

const year = new Date().getFullYear();

const columns = [
  {
    title: 'Get started',
    links: [
      { label: 'Create app', href: LINKS.npm },
      { label: 'Documentation', href: 'https://docs.jilatax.dev' },
      { label: 'GitHub', href: LINKS.github },
      { label: 'CLI', href: 'https://www.npmjs.com/package/@jilatax/cli' },
    ],
  },
  {
    title: 'Packages',
    links: [
      { label: 'jilatax', href: 'https://www.npmjs.com/package/jilatax' },
      { label: 'create-jilatax', href: 'https://www.npmjs.com/package/create-jilatax' },
      { label: '@jilatax/cli', href: 'https://www.npmjs.com/package/@jilatax/cli' },
    ],
  },
  {
    title: 'Stack',
    links: [
      { label: 'Lynx', href: null },
      { label: 'Rspeedy', href: null },
      { label: 'Android', href: null },
      { label: 'TypeScript', href: null },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'npm registry', href: LINKS.npm },
      { label: 'MIT License', href: `${LINKS.github}/blob/main/LICENSE` },
      { label: 'Changelog', href: `${LINKS.github}/releases` },
      { label: 'Status', href: null },
    ],
  },
  {
    title: 'Project',
    links: [
      { label: 'Home', href: '/' },
      { label: 'Use', href: '/#use' },
      { label: 'Packages', href: '/#packages' },
      { label: SITE.name, href: null },
    ],
  },
];
---

<footer class="site-footer">
  <div class="footer-glow" aria-hidden="true"></div>

  <div class="footer-inner">
    <nav class="footer-grid" aria-label="Footer">
      {
        columns.map((col) => (
          <div class="footer-col">
            <h3 class="footer-heading">{col.title}</h3>
            <ul class="footer-list">
              {col.links.map((link) => (
                <li>
                  {link.href ? (
                    <a class="footer-link" href={link.href} {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                      {link.label}
                    </a>
                  ) : (
                    <span class="footer-text">{link.label}</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>

    <p class="footer-copy">{SITE.name} © {year}</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    margin-top: auto;
    padding: 12rem 1.5rem 2.5rem;
    background: var(--color-bg);
  }

  /* Soft horizon glow — green → turquoise, rises high with no hard edge */
  .footer-glow {
    position: absolute;
    inset: auto -15% -12%;
    height: min(72vh, 560px);
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(
        120% 110% at 50% 108%,
        color-mix(in srgb, var(--color-coral) 52%, transparent) 0%,
        color-mix(in srgb, var(--color-orange) 36%, transparent) 30%,
        color-mix(in srgb, var(--color-amber) 18%, transparent) 52%,
        transparent 76%
      ),
      radial-gradient(
        90% 80% at 20% 118%,
        color-mix(in srgb, var(--color-green) 34%, transparent) 0%,
        transparent 70%
      ),
      radial-gradient(
        85% 75% at 80% 115%,
        color-mix(in srgb, var(--color-orange) 30%, transparent) 0%,
        transparent 68%
      );
    filter: blur(32px);
    opacity: 0.58;
    animation: footer-wave 9s ease-in-out infinite;
  }

  :global([data-theme='dark']) .footer-glow {
    opacity: 0.9;
    filter: blur(24px);
  }

  .footer-glow::after {
    content: '';
    position: absolute;
    inset: 0 -25% -15%;
    background: linear-gradient(
      100deg,
      transparent 0%,
      color-mix(in srgb, var(--color-coral) 38%, transparent) 25%,
      color-mix(in srgb, var(--color-orange) 55%, transparent) 50%,
      color-mix(in srgb, var(--color-amber) 32%, transparent) 75%,
      transparent 100%
    );
    background-size: 220% 100%;
    filter: blur(48px);
    opacity: 0.5;
    animation: footer-shimmer 11s ease-in-out infinite;
  }

  :global([data-theme='dark']) .footer-glow::after {
    opacity: 0.72;
  }

  @keyframes footer-wave {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
      opacity: 0.82;
    }
    40% {
      transform: translate3d(-2.5%, -1.5%, 0) scale(1.04);
      opacity: 1;
    }
    70% {
      transform: translate3d(2%, 1%, 0) scale(0.98);
      opacity: 0.88;
    }
  }

  @keyframes footer-shimmer {
    0%,
    100% {
      background-position: 0% 50%;
      opacity: 0.4;
    }
    50% {
      background-position: 100% 50%;
      opacity: 0.7;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-glow,
    .footer-glow::after {
      animation: none;
    }
  }

  .footer-inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem 1.5rem;
  }

  @media (min-width: 720px) {
    .footer-grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 2rem 1.25rem;
    }
  }

  .footer-heading {
    margin: 0 0 1rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer-link,
  .footer-text {
    font-size: 0.95rem;
    line-height: 1.3;
    color: var(--color-text);
    text-decoration: none;
  }

  .footer-link {
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-coral);
  }

  .footer-text {
    opacity: 0.72;
    cursor: default;
  }

  .footer-copy {
    margin: 3.5rem 0 0;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    cursor: default;
  }
</style>
