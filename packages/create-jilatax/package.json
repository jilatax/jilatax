{
  "name": "create-jilatax",
  "version": "0.1.9",
  "packageManager": "bun@1.3.4",
  "description": "Create an Android-first Jilatax application for Lynx and Rspeedy.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-jilatax": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "template", "THIRD_PARTY_NOTICES.md"],
  "sideEffects": ["./dist/bin.js"],

  "keywords": ["android", "creator", "jilatax", "lynx", "rspeedy"],
  "author": "Gohit X (bastndev)",
  "license": "MIT",
  "homepage": "https://jilatax.dev/jilatax",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jilatax/jilatax.git"
  },
  "bugs": {
    "url": "https://github.com/jilatax/jilatax/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18.0"
  },

  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "jilatax": "^0.0.6"
  },

  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@types/node": "^22.20.1",
    "publint": "^0.3.21",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && node test/smoke.mjs",
    "check": "bun run typecheck && bun run test",
    "prepack": "bun run check"
  }
}
