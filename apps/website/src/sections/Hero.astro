---
import { ArrowRight, Check, Copy } from '@lucide/astro';
import GithubIcon from '@/assets/icons/social/github.svg';
import { LINKS } from '@/consts';
---

<section class="hero">
  <div class="announcement-banner">
    <span class="banner-text">🎉 Jilatax v0.0.1 <span class="beta-badge">Beta</span> is officially out! Scaffold production-ready Android apps in seconds.</span>
    <a href="https://docs.jilatax.dev" target="_blank" rel="noopener noreferrer" class="banner-btn">Read the docs</a>
  </div>

  <div class="hero-inner">
    <div class="hero-copy">

      <h1 class="title">
        One command.<br />
        Zero config.<br />
        <span class="gradient-text">Ship Android apps.</span>
      </h1>

      <p class="sub">
        Jilatax is the Android-first application framework for <strong>Lynx</strong> and <strong>Rspeedy</strong>. Scaffold a production-ready project in seconds — the CLI wires up the rest.
      </p>

      <div class="cmd" role="group" aria-label="Install command">
        <span class="cmd-dollar" aria-hidden="true">$</span>
        <code class="cmd-text">{LINKS.command}</code>
        <button class="cmd-copy" type="button" data-copy={LINKS.command} aria-label="Copy install command">
          <Copy class="icon-copy" size={16} aria-hidden="true" />
          <Check class="icon-check" size={16} aria-hidden="true" />
        </button>
      </div>

      <div class="cta">
        <a class="btn btn-primary" href="#box">
          Explore the box <ArrowRight size={16} aria-hidden="true" />
        </a>
        <a class="btn btn-ghost" href={LINKS.github} target="_blank" rel="noopener noreferrer">
          <GithubIcon width={16} height={16} aria-hidden="true" /> GitHub
        </a>
      </div>

      <hr class="divider" />

      <div class="stats">
        <div class="stat" style="--depth: 5px">
          <span class="num coral">3</span>
          <span class="label">npm packages</span>
        </div>
        <div class="stat" style="--depth: 9px">
          <span class="num amber">1</span>
          <span class="label">command to start</span>
        </div>
        <div class="stat" style="--depth: 7px">
          <span class="num green">0</span>
          <span class="label">runtime deps</span>
        </div>
        <div class="stat" style="--depth: 11px">
          <span class="num blue">MIT</span>
          <span class="label">open source</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }
  .hero-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 800px;
  }

  /* ── Announcement Banner ── */
  .announcement-banner {
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: #0e0c09; /* Specific dark background requested */
    border: none;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .banner-text {
    display: inline;
    opacity: 0.95;
  }
  .beta-badge {
    background: #c0c0c0; /* Silver bg */
    color: #110f0b; /* Dark text for contrast */
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    letter-spacing: 0.05em;
  }
  .announcement-banner .banner-btn {
    color: var(--color-coral);
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-left: 0.3rem;
    font-weight: 600;
    transition: color 0.2s ease;
  }
  .announcement-banner .banner-btn:hover {
    color: var(--color-orange);
  }

  .title {
    margin: 0;
    font-size: clamp(2.7rem, 6vw, 4.4rem);
    font-weight: 1000;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .gradient-text {
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .sub {
    margin: 1.4rem auto 0;
    max-width: 34rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.65;
  }
  .sub strong {
    color: var(--color-text);
  }

  /* ── Command chip (the product) ── */
  .cmd {
    margin-top: 2.1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    max-width: 100%;
    padding: 0.9rem 0.65rem 0.9rem 1.25rem;
    border-radius: 14px;
    border: 1px solid #3a3324;
    background: #16130d;
    box-shadow:
      0 18px 45px -18px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    font-family: ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
    font-size: 0.98rem;
  }
  .cmd-dollar {
    color: var(--color-coral);
    font-weight: 700;
    user-select: none;
  }
  .cmd-text {
    color: #f5f1e4;
    white-space: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cmd-text::-webkit-scrollbar {
    display: none;
  }
  .cmd-copy {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border: 1px solid #3a3324;
    border-radius: 9px;
    background: transparent;
    color: #a29a85;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .cmd-copy:hover {
    color: #f5f1e4;
    border-color: #57503c;
  }
  .cmd-copy .icon-check {
    display: none;
    color: var(--color-green);
  }
  .cmd-copy.copied .icon-copy {
    display: none;
  }
  .cmd-copy.copied .icon-check {
    display: block;
  }

  /* ── CTAs ── */
  .cta {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.6rem;
    border-radius: 13px;
    font-weight: 800;
    font-size: 0.97rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease,
      border-color 0.25s ease, color 0.25s ease;
  }
  .btn-primary {
    background: var(--color-coral);
    color: #fff;
    box-shadow: 0 14px 32px -12px var(--color-coral);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 40px -12px var(--color-coral);
  }
  .btn-ghost {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: var(--color-bg-elevated);
  }
  .btn-ghost:hover {
    transform: translateY(-2px);
    border-color: var(--color-text-muted);
  }

  /* ── Stats ── */
  .divider {
    margin: 2.5rem 0 1.75rem;
    border: 0;
    border-top: 1.5px dashed var(--color-border);
    width: 100%;
  }
  .stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2.4rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    transform: translate3d(
      calc(var(--px, 0) * var(--depth)),
      calc(var(--py, 0) * var(--depth)),
      0
    );
  }
  .num {
    font-size: 1.9rem;
    font-weight: 1000;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .coral { color: var(--color-coral); }
  .amber { color: var(--color-amber); }
  .green { color: var(--color-green); }
  .blue { color: var(--color-blue); }
  .label {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 700;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner {
      padding-top: 3rem;
    }
  }
  @media (max-width: 520px) {
    .stats {
      gap: 1.5rem;
    }
    .cmd {
      font-size: 0.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-dot {
      animation: none;
    }
  }
</style>
