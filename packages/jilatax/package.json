{
  "name": "jilatax",
  "version": "0.0.6",
  "packageManager": "bun@1.3.4",
  "description": "Android-first application framework for Lynx and Rspeedy.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schema/app.schema.json": "./schema/app.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "android/README.md",
    "android/build.gradle.kts",
    "android/consumer-rules.pro",
    "android/gradle.properties",
    "android/settings.gradle.kts",
    "android/src",
    "dist",
    "schema",
    "THIRD_PARTY_NOTICES.md"
  ],
  "sideEffects": false,
  "keywords": ["android", "lynx", "lynxjs", "rspeedy", "typescript"],
  "author": "gohit x (bastndev)",
  "license": "MIT",
  "homepage": "https://jilatax.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jilatax/jilatax.git"
  },
  "bugs": {
    "url": "https://github.com/jilatax/jilatax/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "jilatax": {
    "android": "./android",
    "schema": "./schema/app.schema.json"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@types/node": "^22.20.1",
    "publint": "^0.3.21",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && node test/smoke.mjs",
    "check": "bun run typecheck && bun run test",
    "prepack": "bun run check"
  }
}
